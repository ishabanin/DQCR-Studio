{#
  stage_calcid - Materialization: Stage with CalcID
  
  Creates a temporary stage table filtered by CalcID.
  
  Parameters:
    target_table: Имя временной таблицы
    sql: Подготовленный SQL-запрос
    calcid_f110: SQL выражение для получения CalcID
    tool: Database tool (oracle, adb, postgresql)
#}
CREATE TABLE {{ target_table }} AS
SELECT 
    {{ calcid_f110 }} as CalcID,
    t.*
FROM (
    {{ sql }}
) t
