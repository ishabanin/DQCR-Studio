{#
  stage_calcid - Materialization: Stage with CalcID
  
  Creates a temporary stage table filtered by CalcID.
  
  Parameters:
    sql_model: SQLQueryModel
    tool: Database tool (oracle, adb, postgresql)
#}
CREATE TABLE {{ sql_model.target_table }} AS
SELECT 
    {{ calcid_f110 }} as CalcID,
    t.*
FROM (
    {{ sql_model.get_prepared_sql_for_render(tool) }}
) t
