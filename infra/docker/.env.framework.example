# Framework installation mode for backend Docker image.
# Use "local" while developing the framework in the same workspace.
# Use "package" in CI or shared environments to install an exact framework version.

FW_INSTALL_MODE=package
FW_PACKAGE_SPEC=git+ssh://git@your-git-host/FTRepCBR.Workflow.FW.git@v2.0.0

# Runtime backend switches.
FW_USE_CLI=true
FW_CLI_COMMAND=fw2
